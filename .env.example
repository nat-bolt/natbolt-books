# ─────────────────────────────────────────────────────────────────────────────
# NatBolt Book — Environment Variables
# Copy this file to ".env" and fill in your values before running the app.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase project config
# Get from: Firebase Console → Project Settings → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — database (replaces Firestore)
# Get from: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# Note: No service_role key needed. Admin access is controlled by RLS policies
# (books.is_admin() checks the books.admins table). The anon key is sufficient.

# ─────────────────────────────────────────────────────────────────────────────
# Admin configuration
# ─────────────────────────────────────────────────────────────────────────────
# Phone number(s) that can access the /admin panel.
# Format: E.164 (country code + number, no spaces or dashes).
# To add multiple admins, separate with commas: +919876543211,+919999999999
VITE_ADMIN_PHONE=+919876543211
